{
  "name": "cognitiveos",
  "version": "0.3.0",
  "description": "An AI-powered ICM filesystem scaffold for developers with ADHD. Never lose context between sessions.",
  "type": "module",
  "bin": {
    "cognitiveos": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "adhd",
    "icm",
    "cli",
    "context",
    "ai-agent",
    "claude-code",
    "scaffold",
    "productivity"
  ],
  "author": "0xDas (https://x.com/Callmedas69)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Callmedas69/cognitive-OS.git"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
